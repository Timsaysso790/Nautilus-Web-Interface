# ── Security (REQUIRED in production) ────────────────────────────────────────

# JWT signing secret — generate with: openssl rand -hex 32
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32

# Admin account password — must be at least 12 chars
ADMIN_PASSWORD=change-me-strong-password

# Set to "production" to enforce strict security checks at startup
ENVIRONMENT=development

# ── Ports ─────────────────────────────────────────────────────────────────────

# Single exposed port for the whole app (frontend nginx reverse proxy)
NAUTILUS_WEB_PORT=8080

# Backend and admin API are internal only (not exposed directly)

# ── Data Paths ────────────────────────────────────────────────────────────────

# Directory where SQLite databases and persisted data are stored
NAUTILUS_DATA_DIR=./data

# Directory where the ParquetDataCatalog (data lake) lives
# On Unraid, point this at your data lake share, e.g. /mnt/user/nautilus-data-lake
NAUTILUS_CATALOG_PATH=./data_lake

# ── Optional API Key Auth ─────────────────────────────────────────────────────

# Leave empty to use JWT-only authentication (recommended)
# Set to a random string to enable API key auth as alternative: openssl rand -hex 32
API_KEY=

# Admin DB API key (for admin_db_api service)
ADMIN_API_KEY=

# ── Data Source API Keys ──────────────────────────────────────────────────────

# ThetaData API key — https://www.thetadata.net/portal/api_key
THETADATA_API_KEY=

# FRED API key — https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# ── Rate Limiting ─────────────────────────────────────────────────────────────

RATE_LIMIT_PER_MINUTE=200
LOGIN_RATE_LIMIT_PER_MINUTE=5

# ── JWT ───────────────────────────────────────────────────────────────────────

JWT_EXPIRE_HOURS=8
