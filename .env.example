# ── Security (REQUIRED in production) ────────────────────────────────────────
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
ADMIN_PASSWORD=change-me-strong-password-12-chars-min
ENVIRONMENT=development

# ── Ports ─────────────────────────────────────────────────────────────────────
NAUTILUS_WEB_PORT=8080
NAUTILUS_API_PORT=8000

# ── Archive Paths ──────────────────────────────────────────────────────────────
# Point these at your options and equity archives.
# In Docker, the parent directory is mounted at /data/archive/
OPTIONS_ARCHIVE_PATH=/data/archive/Nautilus_Archive5min
EQUITY_ARCHIVE_PATH=/data/archive/Equity_Archive

# ── Scanner ────────────────────────────────────────────────────────────────────
# Shared directory between host cron job and Docker container.
# Host: cron writes scanner results here.
# Docker: container reads from /data/scanner/
SCANNER_DATA_DIR=./scanner_data

# ── Data Paths ────────────────────────────────────────────────────────────────
NAUTILUS_DATA_DIR=./data
NAUTILUS_CATALOG_PATH=./data_lake
ARCHIVE_PATH=./archive

# ── AI Assistant (llama-server or Ollama) ────────────────────────────────────
LLM_BASE_URL=http://localhost:8080
LLM_MODEL=llama
LLM_TYPE=llama
LLM_TIMEOUT=120
LLM_API_KEY=

# ── API Keys ───────────────────────────────────────────────────────────────────
API_KEY=
ADMIN_API_KEY=
THETADATA_API_KEY=
FRED_API_KEY=

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=200
LOGIN_RATE_LIMIT_PER_MINUTE=5

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_EXPIRE_HOURS=8
