# Nautilus Web Interface — Environment Configuration
# Copy this file to .env in the project root.
# Docker Compose reads it automatically and fills the ${VAR:-default} placeholders
# in docker-compose.yml. The backend also loads backend/.env for local dev.

# ── Ports ────────────────────────────────────────────────────────────────
# NAUTILUS_API_PORT=8000
# NAUTILUS_WEB_PORT=8080

# ── Data Archive Paths ──────────────────────────────────────────────────
# Point these at your local parquet archives mounted into the container
OPTIONS_ARCHIVE_PATH=/mnt/aivault/Nautilus_Archive5min
EQUITY_ARCHIVE_PATH=/mnt/aivault/Equity_Archive

# ── Local LLM (AI Assistant) ────────────────────────────────────────────
# For llama-server (OpenAI-compatible API):
# LLM_BASE_URL=http://192.168.1.100:8080
# LLM_MODEL=llama
# LLM_TYPE=llama

# For Ollama:
# LLM_BASE_URL=http://192.168.1.100:11434
# LLM_TYPE=ollama
# LLM_MODEL=llama3.1

# ── Security (production) ────────────────────────────────────────────────
# Generate SECRET_KEY with: openssl rand -hex 32
# ADMIN_PASSWORD=change-me
# ENVIRONMENT=development
# SECRET_KEY=

# ── Data Directories (Docker volume mounts) ─────────────────────────────
# NAUTILUS_DATA_DIR=./data
# NAUTILUS_CATALOG_PATH=./data_lake
# ARCHIVE_PATH=./archive
# SCANNER_DATA_DIR=./scanner_data
